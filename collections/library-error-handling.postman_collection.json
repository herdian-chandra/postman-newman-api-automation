  "item": [
    {
      "name": "AddBook",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set(\"flag\",false);",
              "",
              "const response = pm.response.json();",
              "console.log(response);",
              "const book_id = response.ID;",
              "pm.collectionVariables.set(\"bookId\", book_id)",
              "",
              "// pm.test(\"Validate Status Code is 200\",function(){",
              "//     pm.response.to.have.status(200);",
              "//     pm.expect(response).have.property(\"Msg\");",
              "//     pm.expect(response.Msg).to.eql(\"successfully added\");",
              "// });",
              "",
              "function cleanupScript()",
              "{",
              "    const book_id = generateBookId();",
              "    pm.collectionVariables.set(\"bookId\", book_id)",
              "    pm.collectionVariables.set(\"flag\",true);",
              "    pm.execution.setNextRequest(\"DeleteBook\")",
              "}",
              "",
              "function generateBookId()",
              "{",
              "    const expected_id = pm.collectionVariables.get(\"bookId\")",
              "    return expected_id;",
              "}",
              "",
              "pm.test(\"Validate Status Code is 200\",function(){",
              "    try{",
              "        pm.response.to.have.status(200);",
              "        pm.expect(response).have.property(\"Msg\");",
              "        pm.expect(response.Msg).to.eql(\"successfully added\");",
              "    }",
              "    catch(err){",
              "        if(response.Msg.includes(\"Book Already Exists\")){",
              "            cleanupScript();",
              "        }",
              "    }",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// {",
              "//     \"name\":\"{{$randomFullName}}\",",
              "//     \"isbn\":\"{{$randomBankAccountIban}}\",",
              "//     \"aisle\":\"-123\",",
              "//     \"author\":\"{{$randomFullName}}\"",
              "// }",
              "",
              "// {",
              "//     \"name\":\"{{bookName}}\",",
              "//     \"isbn\":\"{{$randomBankAccountIban}}\",",
              "//     \"aisle\":\"-123\",",
              "//     \"author\":\"{{authorName}}\"",
              "// }",
              "",
              "pm.collectionVariables.set(\"bookName\", pm.iterationData.get(\"firstname\"))",
              "pm.collectionVariables.set(\"authorName\", pm.iterationData.get(\"lastname\"))",
              "// console.log(pm.collectionVariables.get(\"bookName\"))",
              "// console.log(pm.collectionVariables.get(\"authorName\"))"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
