    {
      "name": "Get Single Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json()\r",
              "console.log(response)\r",
              "\r",
              "pm.test(\"Verify Reviewer Email is ruby.andrews@x.dummyjson.com\", function(){\r",
              "    let x = response.reviews[0].reviewerEmail\r",
              "\r",
              "    let getReviwerEmail = \"\"\r",
              "    for(let i = 0; i < response.reviews.length; i++){\r",
              "        // console.log(response.reviews[i].reviewerEmail)\r",
              "        if(response.reviews[i].reviewerEmail === \"ruby.andrews@x.dummyjson.com\"){\r",
              "            getReviwerEmail = response.reviews[i].reviewerEmail\r",
              "            break\r",
              "        }\r",
              "    }\r",
              "    console.log(getReviwerEmail)\r",
              "    pm.expect(getReviwerEmail).to.eql(\"ruby.andrews@x.dummyjson.com\")\r",
              "})\r",
              "\r",
              "pm.test(\"Reviewer email exist (Powerfull Assertion)\", function () {\r",
              "    pm.expect(\r",
              "        response.reviews.some(\r",
              "            r => r.reviewerEmail === \"liam.garcia@x.dummyjson.com\"\r",
              "        )\r",
              "    ).to.be.true\r",
              "})\r",
              "\r",
              "pm.test(\"Search amount of total rating\", function () {\r",
              "    let totalRating = 0\r",
              "    for(let i = 0; i < response.reviews.length; i++){\r",
              "        totalRating = totalRating + response.reviews[i].rating\r",
              "    }\r",
              "    console.log(totalRating)\r",
              "});\r",
              "\r",
              "pm.test(\"Verify total rating of all reviews\", function () {\r",
              "\r",
              "    const totalRating = response.reviews.reduce(\r",
              "        (sum, r) => sum + r.rating, \r",
              "        0\r",
              "    )\r",
              "\r",
              "    console.log(\"Total Rating:\", totalRating)\r",
              "\r",
              "    pm.expect(totalRating).to.be.a(\"number\")\r",
              "    pm.expect(totalRating).to.be.above(0)\r",
              "})\r",
              "\r",
              "pm.test(\"Verify reviewer names\", function () {\r",
              "\r",
              "    const actualReviewerName = response.reviews.map(\r",
              "        r => r.reviewerName\r",
              "    )\r",
              "\r",
              "    const expectedReviewerName = [\r",
              "        \"Liam Garcia\",\r",
              "        \"Ruby Andrews\",\r",
              "        \"Clara Berry\"\r",
              "    ]\r",
              "\r",
              "    console.log(\"Actual:\", actualReviewerName)\r",
              "    console.log(\"Expected:\", expectedReviewerName)\r",
              "\r",
              "    pm.expect(actualReviewerName).to.eql(expectedReviewerName)\r",
              "})"
            ],
