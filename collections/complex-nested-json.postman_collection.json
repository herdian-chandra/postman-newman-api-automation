              "const response = pm.response.json()\r",
              "\r",
              "pm.test(\"Verify reviewer Jace Smith with correct email exists\", function () {\r",
              "\r",
              "    const allReviews = response.products.flatMap(p => p.reviews)\r",
              "    console.log(allReviews)\r",
              "\r",
              "    const isReviewerExist = allReviews.some(\r",
              "        r =>\r",
              "            r.reviewerName === \"Jace Smith\" &&\r",
              "            r.reviewerEmail === \"jace.smith@x.dummyjson.com\"\r",
              "    )\r",
              "\r",
              "    pm.expect(isReviewerExist).to.be.true\r",
              "})\r",
              "\r",
              "pm.test(\"Calculate total rating from all reviews\", function () {\r",
              "\r",
              "    const allReviews = response.products\r",
              "        .flatMap(p => p.reviews)\r",
              "\r",
              "    const totalRating = allReviews.reduce(\r",
              "        (sum, r) => sum + r.rating,\r",
              "        0\r",
              "    )\r",
              "\r",
              "    console.log(\"Total Rating:\", totalRating)\r",
              "\r",
              "    pm.expect(totalRating).to.be.a(\"number\")\r",
              "    pm.expect(totalRating).to.be.above(0)\r",
